# ===========================
# Project Argus — .gitignore
# ===========================

# ── Compiled Binaries ──────────────────────────────
*.exe
*.o
*.a
*.dll
*.so
gui/visualizer
dashboard/dashboard
satellite/satellite

# ── Python ────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
processor/venv/
processor/.venv/
.venv/
*.egg-info/
dist/
build/

# ── Node / npm (just in case) ─────────────────────
node_modules/
npm-debug.log*

# ── Docker local volumes ───────────────────────────
postgres_data/
minio_data/
redpanda_data/

# ── Data buffers (keep dirs, ignore content) ───────
downlink_buffer/*
!downlink_buffer/.gitkeep
local_sync/*
!local_sync/.gitkeep

# ── Large satellite data files ─────────────────────
*.zip
*.zipZone.Identifier
*.tif
*.tiff
*.npy
# Uncomment below to track embeddings (large files — use Git LFS instead)
# !processor/embeddings.npy
# !processor/lats.npy
# !processor/lons.npy

# ── Raw satellite scene directories ───────────────
R*/

# ── Tiles (large image dataset — use Git LFS) ─────
tiles/*.jpg
tiles/*.png
!tiles/.gitkeep

# ── Logs ──────────────────────────────────────────
*.log
/tmp/argus_gui.log

# ── IDEs ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
